# SCIM 2.0 Service Provider Configuration
# Copy this file to .env and configure as needed

# Server Configuration
HOST=0.0.0.0
PORT=5000
BASE_URL=http://localhost:5000
DEBUG=True

# CORS Configuration
# For local development, use '*' to allow all origins
# For production, specify allowed origins separated by commas
# Example: https://app.example.com,https://admin.example.com
CORS_ORIGINS=*

# Production Deployment (Render)
# When deploying to Render, set these environment variables in the Render dashboard:
# BASE_URL=https://your-app-name.onrender.com
# DEBUG=False
# CORS_ORIGINS=https://your-frontend-domain.com

# JWT Authentication Configuration
AUTH_OAUTH_ENABLED=true
AUTH_JWT_ENABLED=true
AUTH_JWT_ISSUER=https://test-idp.example.com
AUTH_JWT_AUDIENCE=scim-service-provider
AUTH_JWT_ALGORITHM=RS256

# JWT Public Key (get from http://localhost:5000/api/dev/tokens/public-key)
AUTH_JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----
MIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8AMIIBCgKCAQEAu32/Sy9xgTRZzoXh4qKF
Dbu4DpoENfUrj4Z1XraHYY+h9nCqGM+vOtdXLLZtqc2yold1DgwgUgf1Z9bw4uyt
t2mLLDro4zNlGzCGpbwmUyMOqHn8Mscr4xEvpf3DtA9sVfzgJxV11SBADzHBJG5S
fayf/whCMU/AIk5dceSQToh/oLaWd6QmfxFhRjdNCclibDqCWfcl/zloFSYf0DAJ
8IygJZfMdz/T7erlj27hvcpXSn8pjZ6970g+NObyszqyKRBIYSJlf5ClzLmb5ZDh
7MvLPnEuOX6MwPdjPrsNi66hz9RUOyMmyFK4tu8Mw7MxDi3PVPxgzEFimeGAP7UI
eQIDAQAB
-----END PUBLIC KEY-----

# Basic Authentication Configuration
AUTH_BASIC_ENABLED=true
# Format: username:sha256_hash,username2:sha256_hash2
# admin:admin123 (hash: 8c6976e5b5410415bde908bd4dee15dfb167a9c873fc4bb8a81f6f2ab448a918)
AUTH_BASIC_USERS=admin:8c6976e5b5410415bde908bd4dee15dfb167a9c873fc4bb8a81f6f2ab448a918

# Mutual TLS Configuration
AUTH_MTLS_ENABLED=true
AUTH_MTLS_REQUIRE_CERT=false
# AUTH_MTLS_CA_CERTS_PATH=/path/to/ca-certs.pem

# Authorization Configuration
AUTH_ENFORCE_AUTHZ=true