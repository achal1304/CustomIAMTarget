# SCIM 2.0 Service Provider Configuration
# Copy this file to .env and configure as needed

# Server Configuration
HOST=0.0.0.0
PORT=5000
BASE_URL=http://localhost:5000
DEBUG=True

# Bearer Token (JWT) Authentication Configuration
# Note: This validates JWT bearer tokens, not full OAuth flows
AUTH_OAUTH_ENABLED=true
AUTH_JWT_ENABLED=true
AUTH_JWT_ISSUER=https://test-idp.example.com
AUTH_JWT_AUDIENCE=scim-service-provider
AUTH_JWT_ALGORITHM=RS256

# JWT Public Key (get from http://localhost:5000/api/dev/tokens/public-key)
# Multi-line value - use quotes and \n for newlines
AUTH_JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nMIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8AMIIBCgKCAQEAwHJUJbufLISs0FjJx/vB\nC2afDVzr7igVBwpwbnlvjx1i3lmPhn8J90qN9mb2fCSUfsdwKOIV3OApEhnLsQVF\nIJnlrnDmehgZqxwKgw2raA2TGm94+awg5SEuqMeXNiA85EruhHXsPety4f1EG+An\nTAyVAlQlwHdX5v/OPDpLCKkxgJE+CkguBnT2GM+9K10dqlVxdGKy9q8WglOPlNxd\nFQPo0go6AJpzCyvOARfnlSFL+9U/Kz7uxEPzV8L5roMGQFjpl5nZ9Rp1ZV3meawx\nj2aduZLaerzQ762N+Fpz+VGmkcKkMddmDCswP+hYGOcIsLFKOE/cTIXViAU891zg\nKQIDAQAB\n-----END PUBLIC KEY-----"

# Basic Authentication Configuration
AUTH_BASIC_ENABLED=false
# Format: username:sha256_hash,username2:sha256_hash2
# admin:admin123, readonly:readonly123, testuser:testpass123
AUTH_BASIC_USERS=admin:240be518fabd2724ddb6f04eeb1da5967448d7e831c08c8fa822809f74c720a9,readonly:92913bb6e702dacb44322bd2a488153895fb4b2bf8247366b40381206a29f4e5,testuser:7e6e0c3079a08c5cc6036789b57e951f65f82383913ba1a49ae992544f1b4b6e

# Mutual TLS Configuration
AUTH_MTLS_ENABLED=false
AUTH_MTLS_REQUIRE_CERT=false
# AUTH_MTLS_CA_CERTS_PATH=/path/to/ca-certs.pem

# Authorization Configuration
AUTH_ENFORCE_AUTHZ=true